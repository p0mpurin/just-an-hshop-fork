    switch (p1) {
        case 1:
            return "Wedi ffeindio %1 teitl coll\nGwelwch y ciw i'w osod.";
        
        case 2:
            return "Wedi ffeindio %1 deitl coll\nGwelwch y ciw i'w gosod.";
        
        case 3: case 6:
            return "Wedi ffeindio %1 theitl coll\nGwelwch y ciw i'w gosod.";
        
        default:
            return "Wedi ffeindio %1 teitl coll\nGwelwch y ciw i'w gosod.";
    }
} else {
    return "Wedi ffeindio %1 o deitlau coll\nGwelwch y ciw i'w gosod.";
}

